      <column caption='Proper Country Name' datatype='string' name='[Calculation_1336443201511575552]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='UPPER(LEFT([Country], 1)) + LOWER(MID([Country], 2, LEN([Country]) - 1))' />
      </column>
      <column caption='Proper Industry' datatype='string' name='[Calculation_1336443201517699073]' role='dimension' type='nominal'>
