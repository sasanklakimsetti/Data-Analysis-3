      <aliases enabled='yes' />
      <column caption='Exchange Long Name' datatype='string' name='[Calculation_692991405086466048]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Exchange]=&quot;BTS&quot; THEN &quot;Bithumb Securities (Cryptocurrency Exchange)&quot;&#13;&#10;ELSEIF [Exchange]=&quot;NGM&quot; THEN &quot;Nasdaq Global Market&quot;&#13;&#10;ELSEIF [Exchange]=&quot;NMS&quot; THEN &quot;National Market System&quot;&#13;&#10;ELSEIF [Exchange]=&quot;NYQ&quot; THEN &quot;New York Stock Exchange&quot;&#13;&#10;END' />
      </column>
      <column caption='Cleaned CurrentPrice' datatype='real' name='[Calculation_692991405094723585]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Currentprice], { AVG([Currentprice]) })' />
      </column>
      <column caption='Cleaned MarketCap' datatype='real' name='[Calculation_692991405095514114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Marketcap], { AVG([Marketcap]) })' />
      </column>
      <column caption='Cleaned Revenuegrowth' datatype='real' name='[Calculation_692991405095612419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Revenuegrowth], { AVG([Revenuegrowth]) })' />
      </column>
      <column caption='Cleaned Weight' datatype='real' name='[Calculation_692991405095903236]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Weight], { AVG([Weight]) })' />
      </column>
      <column caption='Cleaned FullTimeEmployee' datatype='real' name='[Calculation_692991405096501253]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Fulltimeemployees], { AVG([Fulltimeemployees]) })' />
      </column>
      <column caption='Cleaned Ebitda' datatype='real' name='[Calculation_692991405096599558]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Ebitda], { AVG([Ebitda]) })' />
      </column>
      <column caption='Cleaned Volume' datatype='real' name='[Calculation_692991405096808455]' role='measure' type='quantitative'>
